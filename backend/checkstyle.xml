<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Manalith Checkstyle configuration — simplified Google Java Style.
    Max line length: 120 characters.
    Enforces braces, Javadoc on public methods, no star imports (except static),
    and a handful of code-quality rules.
-->
<module name="Checker">

    <property name="charset" value="UTF-8"/>
    <property name="severity" value="warning"/>
    <property name="fileExtensions" value="java"/>

    <!-- ── File-level checks ─────────────────────────────────────────── -->

    <!-- No tab characters in source files -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <!-- Maximum line length -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
    </module>

    <!-- ── Tree-walker checks (AST-based) ────────────────────────────── -->
    <module name="TreeWalker">

        <!-- All control structures must have braces -->
        <module name="NeedBraces"/>

        <!-- If you override equals() you must also override hashCode() -->
        <module name="EqualsHashCode"/>

        <!-- Local variables that are never reassigned should be final -->
        <module name="FinalLocalVariable">
            <property name="tokens" value="VARIABLE_DEF,PARAMETER_DEF"/>
        </module>

        <!-- No whitespace after certain tokens (e.g., unary operators) -->
        <module name="NoWhitespaceAfter">
            <property name="tokens"
                      value="AT,INC,DEC,UNARY_MINUS,UNARY_PLUS,BNOT,LNOT,DOT,ARRAY_DECLARATOR,INDEX_OP"/>
        </module>

        <!-- Binary operators should be on the next line when wrapping -->
        <module name="OperatorWrap">
            <property name="option" value="NL"/>
            <property name="tokens"
                      value="BAND,BOR,BSR,BXOR,DIV,EQUAL,GE,GT,LAND,LE,LITERAL_INSTANCEOF,
                             LOR,LT,MINUS,MOD,NOT_EQUAL,PLUS,QUESTION,SL,SR,STAR,METHOD_REF"/>
        </module>

        <!-- Whitespace around common tokens -->
        <module name="WhitespaceAround">
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyLambdas" value="true"/>
            <property name="allowEmptyMethods" value="true"/>
            <property name="allowEmptyTypes" value="true"/>
            <property name="allowEmptyLoops" value="true"/>
            <property name="tokens"
                      value="ASSIGN,BAND,BAND_ASSIGN,BOR,BOR_ASSIGN,BSR,BSR_ASSIGN,BXOR,
                             BXOR_ASSIGN,COLON,DIV,DIV_ASSIGN,DO_WHILE,EQUAL,GE,GT,LAMBDA,
                             LAND,LCURLY,LE,LITERAL_CATCH,LITERAL_DO,LITERAL_ELSE,
                             LITERAL_FINALLY,LITERAL_FOR,LITERAL_IF,LITERAL_RETURN,
                             LITERAL_SWITCH,LITERAL_SYNCHRONIZED,LITERAL_TRY,LITERAL_WHILE,
                             LOR,LT,MINUS,MINUS_ASSIGN,MOD,MOD_ASSIGN,NOT_EQUAL,PLUS,
                             PLUS_ASSIGN,QUESTION,RCURLY,SL,SLIST,SL_ASSIGN,SR,SR_ASSIGN,
                             STAR,STAR_ASSIGN,LITERAL_ASSERT,TYPE_EXTENSION_AND"/>
        </module>

        <!-- Blank line required after class / method / field definitions -->
        <module name="EmptyLineSeparator">
            <property name="allowNoEmptyLineBetweenFields" value="true"/>
            <property name="tokens"
                      value="IMPORT,STATIC_IMPORT,CLASS_DEF,INTERFACE_DEF,ENUM_DEF,
                             STATIC_INIT,INSTANCE_INIT,METHOD_DEF,CTOR_DEF,VARIABLE_DEF,RECORD_DEF,COMPACT_CTOR_DEF"/>
        </module>

        <!-- Public methods should have Javadoc (missing param/return tags are allowed) -->
        <module name="JavadocMethod">
            <property name="accessModifiers" value="public"/>
            <property name="allowMissingParamTags" value="true"/>
            <property name="allowMissingReturnTag" value="true"/>
        </module>

        <!-- Use uppercase L for long literals (1000L not 1000l) -->
        <module name="UpperEll"/>

        <!-- Exception classes should not have mutable fields -->
        <module name="MutableException"/>

        <!-- No unused imports -->
        <module name="UnusedImports"/>

        <!-- No wildcard imports, except static (e.g., import static org.assertj.core.api.Assertions.*) -->
        <module name="AvoidStarImport">
            <property name="allowStaticMemberImports" value="true"/>
        </module>

    </module>

</module>
